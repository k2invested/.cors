{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cors.local/schemas/semantic_skeleton.v1.json",
  "title": "cors semantic_skeleton.v1",
  "description": "Unified author-time semantic skeleton for entity, action, or hybrid artifacts. Entity semantics and workflow structure share one envelope without collapsing their meanings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "artifact",
    "name",
    "desc",
    "trigger",
    "refs"
  ],
  "properties": {
    "version": {
      "const": "semantic_skeleton.v1"
    },
    "artifact": {
      "$ref": "#/$defs/artifact"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "desc": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "string",
      "pattern": "^(manual|every_turn|on_mention|on_contact:[A-Za-z0-9_\\-]+|on_vocab:[A-Za-z0-9_\\-]+|scheduled:[A-Za-z0-9_\\-]+|command:[A-Za-z0-9_\\-]+)$"
    },
    "refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "existing_ref": {
      "type": "string",
      "minLength": 1
    },
    "semantics": {
      "$ref": "#/$defs/semantics"
    },
    "root": {
      "$ref": "#/$defs/identifier"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://cors.local/schemas/skeleton.v1.json#/$defs/phase"
      }
    },
    "closure": {
      "$ref": "https://cors.local/schemas/skeleton.v1.json#/$defs/closure"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_\\-]*$"
    },
    "artifactKind": {
      "enum": [
        "entity",
        "action",
        "hybrid"
      ]
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "$ref": "#/$defs/artifactKind"
        },
        "protected_kind": {
          "enum": [
            "generic",
            "entity",
            "action",
            "codon"
          ]
        },
        "lineage": {
          "$ref": "#/$defs/identifier"
        },
        "version_strategy": {
          "enum": [
            "hash_pinned",
            "lineage_latest",
            "manual"
          ]
        }
      }
    },
    "semantics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "identity": {
          "type": "object"
        },
        "preferences": {
          "type": "object"
        },
        "constraints": {
          "type": "object"
        },
        "sources": {
          "type": "array"
        },
        "scope": {
          "type": "string"
        },
        "schema": {
          "type": "object"
        },
        "access_rules": {
          "type": "object"
        },
        "principles": {
          "type": "array"
        },
        "boundaries": {
          "type": "array"
        },
        "domain_knowledge": {
          "type": "object"
        },
        "init": {
          "type": "object"
        },
        "entity_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "artifact": {
            "properties": {
              "kind": {
                "const": "entity"
              }
            },
            "required": [
              "kind"
            ]
          }
        }
      },
      "then": {
        "required": [
          "semantics"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "artifact": {
            "properties": {
              "kind": {
                "enum": [
                  "action",
                  "hybrid"
                ]
              }
            },
            "required": [
              "kind"
            ]
          }
        }
      },
      "then": {
        "required": [
          "root",
          "phases",
          "closure"
        ]
      }
    }
  ]
}
