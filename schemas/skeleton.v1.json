{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cors.local/schemas/skeleton.v1.json",
  "title": "cors skeleton.v1",
  "description": "Author-time planning skeleton for deterministic compilation into stepchain.v1 and optional lowering into .st or workflow JSON. Structural law lives in the skeleton. Exact curated package activation can be carried separately via symbolic hash refs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "name",
    "desc",
    "trigger",
    "refs",
    "root",
    "phases",
    "closure"
  ],
  "properties": {
    "version": {
      "const": "skeleton.v1"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "desc": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "string",
      "pattern": "^(manual|every_turn|on_mention|on_contact:[A-Za-z0-9_\\-]+|on_vocab:[A-Za-z0-9_\\-]+|scheduled:[A-Za-z0-9_\\-]+|command:[A-Za-z0-9_\\-]+)$"
    },
    "refs": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "root": {
      "$ref": "#/$defs/identifier"
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/phase"
      }
    },
    "closure": {
      "$ref": "#/$defs/closure"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_\\-]*$"
    },
    "symbolicRef": {
      "type": "string",
      "pattern": "^(@[A-Za-z][A-Za-z0-9_\\-]*|\\$prev|\\$origin|\\$commit|\\$phase:[A-Za-z][A-Za-z0-9_\\-]*|[A-Za-z0-9_:\\-./]+)$"
    },
    "topLevelRefName": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_\\-]*$"
    },
    "transitionMap": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "pattern": "^on_[a-z][a-z_]*$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/identifier"
      }
    },
    "gapTemplate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "desc",
        "content_refs",
        "step_refs"
      ],
      "properties": {
        "desc": {
          "type": "string",
          "minLength": 1
        },
        "content_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/symbolicRef"
          }
        },
        "step_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/symbolicRef"
          }
        }
      }
    },
    "injectConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 2.0
        }
      }
    },
    "kernelClass": {
      "enum": [
        "observe",
        "mutate",
        "bridge",
        "clarify"
      ]
    },
    "dispersalMode": {
      "enum": [
        "context",
        "action",
        "mixed",
        "embed"
      ]
    },
    "executionMode": {
      "enum": [
        "runtime_vocab",
        "curated_step_hash",
        "inline"
      ]
    },
    "awaitPolicy": {
      "enum": [
        "none",
        "manual",
        "heartbeat"
      ]
    },
    "protectedKind": {
      "enum": [
        "generic",
        "entity",
        "action",
        "codon"
      ]
    },
    "spawnMode": {
      "enum": [
        "none",
        "context",
        "action",
        "mixed",
        "embed"
      ]
    },
    "spawnTrigger": {
      "enum": [
        "none",
        "on_manifest",
        "on_post_diff",
        "conditional"
      ]
    },
    "branchPolicy": {
      "enum": [
        "depth_first_to_parent",
        "depth_first_to_root"
      ]
    },
    "siblingPolicy": {
      "enum": [
        "after_descendants"
      ]
    },
    "returnPolicy": {
      "enum": [
        "resume_parent",
        "resume_transition",
        "terminal"
      ]
    },
    "generation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spawn_mode",
        "spawn_trigger",
        "branch_policy",
        "sibling_policy",
        "return_policy"
      ],
      "properties": {
        "spawn_mode": {
          "$ref": "#/$defs/spawnMode"
        },
        "spawn_trigger": {
          "$ref": "#/$defs/spawnTrigger"
        },
        "branch_policy": {
          "$ref": "#/$defs/branchPolicy"
        },
        "sibling_policy": {
          "$ref": "#/$defs/siblingPolicy"
        },
        "return_policy": {
          "$ref": "#/$defs/returnPolicy"
        },
        "max_generation_depth": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "spawn_mode": {
                "const": "none"
              }
            },
            "required": [
              "spawn_mode"
            ]
          },
          "then": {
            "properties": {
              "spawn_trigger": {
                "const": "none"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "spawn_mode": {
                "enum": [
                  "context",
                  "action",
                  "mixed",
                  "embed"
                ]
              }
            },
            "required": [
              "spawn_mode"
            ]
          },
          "then": {
            "properties": {
              "spawn_trigger": {
                "enum": [
                  "on_manifest",
                  "on_post_diff",
                  "conditional"
                ]
              }
            }
          }
        }
      ]
    },
    "manifestation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kernel_class",
        "dispersal",
        "execution_mode"
      ],
      "properties": {
        "kernel_class": {
          "$ref": "#/$defs/kernelClass"
        },
        "dispersal": {
          "$ref": "#/$defs/dispersalMode"
        },
        "execution_mode": {
          "$ref": "#/$defs/executionMode"
        },
        "runtime_vocab": {
          "$ref": "#/$defs/anyRuntimeVocab"
        },
        "activation_ref": {
          "$ref": "#/$defs/symbolicRef"
        },
        "activation_alias": {
          "$ref": "#/$defs/identifier"
        },
        "background": {
          "type": "boolean"
        },
        "await_policy": {
          "$ref": "#/$defs/awaitPolicy"
        },
        "protected_kind": {
          "$ref": "#/$defs/protectedKind"
        },
        "emits_commit": {
          "type": "boolean"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "execution_mode": {
                "const": "runtime_vocab"
              }
            },
            "required": [
              "execution_mode"
            ]
          },
          "then": {
            "required": [
              "runtime_vocab"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "execution_mode": {
                "const": "curated_step_hash"
              }
            },
            "required": [
              "execution_mode"
            ]
          },
          "then": {
            "required": [
              "activation_ref"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "kernel_class": {
                "const": "clarify"
              }
            },
            "required": [
              "kernel_class"
            ]
          },
          "then": {
            "properties": {
              "runtime_vocab": {
                "const": "clarify_needed"
              }
            }
          }
        }
      ]
    },
    "observeVocab": {
      "enum": [
        "hash_resolve_needed",
        "pattern_needed",
        "mailbox_needed",
        "external_context"
      ]
    },
    "mutateVocab": {
      "enum": [
        "hash_edit_needed",
        "stitch_needed",
        "content_needed",
        "command_needed",
        "email_needed",
        "json_patch_needed",
        "git_revert_needed"
      ]
    },
    "bridgeVocab": {
      "enum": [
        "clarify_needed",
        "reason_needed",
        "vocab_reg_needed",
        "await_needed",
        "tool_needed",
        "reprogramme_needed"
      ]
    },
    "anyRuntimeVocab": {
      "enum": [
        "hash_resolve_needed",
        "pattern_needed",
        "mailbox_needed",
        "external_context",
        "clarify_needed",
        "hash_edit_needed",
        "stitch_needed",
        "content_needed",
        "command_needed",
        "email_needed",
        "json_patch_needed",
        "git_revert_needed",
        "reason_needed",
        "vocab_reg_needed",
        "await_needed",
        "tool_needed",
        "reprogramme_needed"
      ]
    },
    "phaseBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "goal",
        "action"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "kind": {
          "enum": [
            "observe",
            "reason",
            "mutate",
            "verify",
            "higher_order",
            "clarify",
            "await",
            "embed",
            "terminal"
          ]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "$ref": "#/$defs/identifier"
        },
        "gap_template": {
          "$ref": "#/$defs/gapTemplate"
        },
        "manifestation": {
          "$ref": "#/$defs/manifestation"
        },
        "generation": {
          "$ref": "#/$defs/generation"
        },
        "allowed_vocab": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/anyRuntimeVocab"
          }
        },
        "post_diff": {
          "type": "boolean"
        },
        "resolve": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/topLevelRefName"
          }
        },
        "transitions": {
          "$ref": "#/$defs/transitionMap"
        },
        "requires_postcondition": {
          "type": "boolean"
        },
        "inject": {
          "$ref": "#/$defs/injectConfig"
        },
        "embed": {
          "oneOf": [
            {
              "$ref": "#/$defs/symbolicRef"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/symbolicRef"
              }
            }
          ]
        },
        "terminal": {
          "type": "boolean"
        }
      }
    },
    "observePhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "observe"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/observeVocab"
                  },
                  {
                    "$ref": "#/$defs/bridgeVocab"
                  }
                ]
              }
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions"
          ]
        }
      ]
    },
    "reasonPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "reason"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/observeVocab"
                  },
                  {
                    "$ref": "#/$defs/mutateVocab"
                  },
                  {
                    "$ref": "#/$defs/bridgeVocab"
                  }
                ]
              }
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions"
          ]
        }
      ]
    },
    "mutatePhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "mutate"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/mutateVocab"
                  },
                  {
                    "$ref": "#/$defs/bridgeVocab"
                  }
                ]
              }
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions"
          ]
        }
      ]
    },
    "verifyPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "verify"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "anyOf": [
                  {
                    "$ref": "#/$defs/observeVocab"
                  },
                  {
                    "$ref": "#/$defs/bridgeVocab"
                  }
                ]
              }
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions"
          ]
        }
      ]
    },
    "higherOrderPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "higher_order"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/bridgeVocab"
              }
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions"
          ]
        }
      ]
    },
    "clarifyPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "clarify"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "items": {
                "const": "clarify_needed"
              }
            },
            "terminal": {
              "const": true
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "terminal"
          ]
        }
      ]
    },
    "awaitPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "await"
            },
            "allowed_vocab": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "enum": [
                  "await_needed",
                  "reason_needed"
                ]
              }
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions"
          ]
        }
      ]
    },
    "embedPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "embed"
            }
          },
          "required": [
            "gap_template",
            "manifestation",
            "generation",
            "allowed_vocab",
            "post_diff",
            "transitions",
            "embed"
          ]
        }
      ]
    },
    "terminalPhase": {
      "allOf": [
        {
          "$ref": "#/$defs/phaseBase"
        },
        {
          "properties": {
            "kind": {
              "const": "terminal"
            },
            "terminal": {
              "const": true
            }
          },
          "required": [
            "terminal"
          ]
        }
      ]
    },
    "phase": {
      "oneOf": [
        {
          "$ref": "#/$defs/observePhase"
        },
        {
          "$ref": "#/$defs/reasonPhase"
        },
        {
          "$ref": "#/$defs/mutatePhase"
        },
        {
          "$ref": "#/$defs/verifyPhase"
        },
        {
          "$ref": "#/$defs/higherOrderPhase"
        },
        {
          "$ref": "#/$defs/clarifyPhase"
        },
        {
          "$ref": "#/$defs/awaitPhase"
        },
        {
          "$ref": "#/$defs/embedPhase"
        },
        {
          "$ref": "#/$defs/terminalPhase"
        }
      ]
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "success",
        "failure",
        "limits"
      ],
      "properties": {
        "success": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requires_terminal",
            "requires_no_active_gaps"
          ],
          "properties": {
            "requires_terminal": {
              "$ref": "#/$defs/identifier"
            },
            "requires_no_active_gaps": {
              "type": "boolean"
            }
          }
        },
        "failure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allow_force_close",
            "allow_clarify_terminal"
          ],
          "properties": {
            "allow_force_close": {
              "type": "boolean"
            },
            "allow_clarify_terminal": {
              "type": "boolean"
            }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "max_chain_depth",
            "max_redirects"
          ],
          "properties": {
            "max_chain_depth": {
              "type": "integer",
              "minimum": 1
            },
            "max_redirects": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    }
  }
}
